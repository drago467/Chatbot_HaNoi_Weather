{
  "executive_summary": {
    "architecture": "ReAct Agent (LangGraph) + Function Calling + SLM Router",
    "coverage": "126 wards, 30 districts, city-level",
    "key_metrics": {
      "tool_accuracy": "91.8% single-turn, 96.3% multi-turn",
      "csr": "90.0%",
      "era": "92.0%",
      "avg_crr": "2.93 turns"
    }
  },
  "metric_definitions": {
    "tool_accuracy": {
      "definition": "Percentage where at least ONE expected tool called for intent",
      "formula": "tool_correct_count / total * 100",
      "scope_aware": true,
      "wilson_ci": "95% confidence interval",
      "value": "91.8% (CI: 86.7%-95.1%)"
    },
    "csr": {
      "definition": "Percentage of conversations where ALL turns had correct tools",
      "formula": "conversations_with_all_correct / total * 100",
      "value": "90.0%"
    },
    "era": {
      "definition": "Percentage of context turns where entity resolved correctly",
      "formula": "context_resolved / total_context_turns * 100",
      "value": "92.0%"
    }
  },
  "key_files": {
    "evaluation": "app/agent/evaluate.py (1291 lines)",
    "agent": "app/agent/agent.py (1600+ lines)",
    "tool_mapper": "app/agent/router/tool_mapper.py",
    "data_single_turn": "data/evaluation/routed_v5/evaluation_summary.json",
    "data_multi_turn": "data/evaluation/verify_v2/multi_turn/summary_routed.json"
  }
}